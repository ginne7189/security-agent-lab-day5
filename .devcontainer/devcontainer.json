{
  "name": "Security Agent Lab",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt && cp -n .env.example .env || true",
  "postAttachCommand": "python check_env.py || true",
  "customizations": {
    "vscode": { "extensions": ["ms-python.python", "ms-python.vscode-pylance"] }
  },
  "remoteEnv": { "PYTHONPATH": "${containerWorkspaceFolder}" }
}
